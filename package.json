{
  "name": "opoclaw",
  "version": "1.0.0",
  "description": "Your personal Claude Code assistant, delivered to your phone via Telegram",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "setup": "tsx scripts/setup.ts",
    "status": "tsx scripts/status.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.34",
    "@hono/node-server": "^1.19.9",
    "@playwright/test": "^1.58.2",
    "@slack/web-api": "^7.14.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.8.1",
    "ccxt": "^4.5.42",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "cron-parser": "^5.5.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.19.0",
    "grammy": "^1.34.0",
    "hono": "^4.12.3",
    "multer": "^2.1.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.34.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@vitest/coverage-v8": "^2.0.0",
    "playwright": "^1.58.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "vitest": {
    "environment": "node",
    "include": [
      "src/**/*.test.ts"
    ]
  }
}
