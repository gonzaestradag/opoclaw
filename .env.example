# ── OpoClaw — Example Environment File ────────────────────────────────────────
# Copy this to .env and fill in your values.
# Run ./install.sh for a guided setup wizard.
# Full docs: SETUP.md

# ── Required ───────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID. Start the bot, send it any message, then visit:
# https://api.telegram.org/botYOUR_TOKEN/getUpdates — look for "chat":{"id":...}
ALLOWED_CHAT_ID=

# ── Claude Auth ────────────────────────────────────────────────────────────────
# Option A: OAuth (recommended for personal use — uses your Claude.ai account)
# Run: claude login   — auth is stored in ~/.claude/ automatically, no key needed here.
# Leave ANTHROPIC_API_KEY blank when using OAuth.

# Option B: API key (recommended for server/always-on deployments)
# Get at: https://console.anthropic.com/keys
# WARNING: This takes billing precedence over OAuth. Leave blank if using claude login.
# ANTHROPIC_API_KEY=

# Override which Claude account is used (optional, advanced)
# CLAUDE_CODE_OAUTH_TOKEN=

# ── Voice ──────────────────────────────────────────────────────────────────────
# Groq — free tier, for voice transcription (Whisper converts your voice notes to text)
# Get at: https://console.groq.com
GROQ_API_KEY=

# ElevenLabs — for voice responses (clone your own voice!)
# Get at: https://elevenlabs.io
# After sign-up: Voices > Add Voice > Instant Voice Clone — copy the Voice ID
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Core AI Keys ───────────────────────────────────────────────────────────────
# OpenAI — for market intelligence analysis and agent avatar generation (DALL-E 3)
# Get at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini — for Gemini-powered agents and VisionClaw glasses integration
# Get at: https://aistudio.google.com (free tier available)
GOOGLE_API_KEY=

# OpenRouter — optional fallback routing when primary APIs hit rate limits
# Get at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── Multi-Agent LLM Keys ───────────────────────────────────────────────────────
# Moonshot AI (Kimi K2) — used by Marcus (CTO), Lucas (Frontend), Elias (Backend) agents
# Get at: https://platform.moonshot.cn/console/api-keys
# If skipped, those agents fall back to OpenAI or Gemini automatically.
MOONSHOT_API_KEY=

# ── Dashboard ─────────────────────────────────────────────────────────────────
# Web dashboard for monitoring agents, tasks, activity, trading, and system health.
# Generate a token: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
DASHBOARD_TOKEN=
# Default port is 3001. Change only if you have a port conflict.
# DASHBOARD_PORT=3001
# Set to your Cloudflare Tunnel public URL once tunnel is configured.
# DASHBOARD_URL=https://your-subdomain.your-domain.com

# ── Internal Ports ─────────────────────────────────────────────────────────────
# Bot inject server — used internally by tg-notify.sh (change only if 3142 is taken)
# BOT_INJECT_PORT=3142

# ── Google OAuth (for Gmail + Calendar skills) ─────────────────────────────────
# These paths point to OAuth credentials files downloaded from Google Cloud Console.
# See SETUP.md for the full step-by-step guide.
GOOGLE_CREDS_PATH=~/.config/gmail/credentials.json
GMAIL_TOKEN_PATH=~/.config/gmail/token.json
GCAL_TOKEN_PATH=~/.config/calendar/token.json

# ── Cloudflare Tunnel (optional, for remote access) ────────────────────────────
# Gives you a public HTTPS URL for your dashboard and VisionClaw connectivity.
# Get at: dash.cloudflare.com > Zero Trust > Networks > Tunnels > Create tunnel
# CLOUDFLARE_TUNNEL_TOKEN=

# ── Vapi (phone calls, optional) ───────────────────────────────────────────────
# Enables your assistant to make and receive phone calls.
# Get at: https://vapi.ai
# VAPI_API_KEY=
# VAPI_ASSISTANT_ID=
# VAPI_PHONE_NUMBER=
# VAPI_WEBHOOK_SECRET=
# VAPI_ALLOWED_CALLERS=   # Comma-separated list of allowed caller phone numbers

# ── Binance (trading bots, optional) ───────────────────────────────────────────
# Powers the Satoshi and Nakamoto trading bots (freqtrade strategies).
# WARNING: Only enable paper/test trading until you understand the strategy.
# Get at: binance.com > API Management. Enable Spot trading, add your server IP.
# BINANCE_API_KEY=
# BINANCE_SECRET_KEY=

# ── Slack (optional) ───────────────────────────────────────────────────────────
# Slack User OAuth Token — starts with xoxp-
# See README for step-by-step Slack app setup.
# SLACK_USER_TOKEN=

# ── WhatsApp Bridge (optional, advanced) ───────────────────────────────────────
# Requires running scripts/wa-daemon.ts separately. See README.
# WHATSAPP_ENABLED=true

# ── Dashboard Auth (username/password login, optional) ─────────────────────────
# Adds a login form to the dashboard in addition to the token.
# Generate hash: node -e "const b=require('bcryptjs');b.hash('yourpassword',10).then(console.log)"
# DASHBOARD_USERNAME=admin
# DASHBOARD_PASSWORD_HASH=

# ── Budget Tracking ────────────────────────────────────────────────────────────
# Monthly AI spend budget in USD. Jordan (Finance agent) monitors this.
# BUDGET_USD=50.0

# ── Node Environment ───────────────────────────────────────────────────────────
NODE_ENV=production
